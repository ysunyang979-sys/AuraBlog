<div class="page-detail">
  <% if (page.type === "locked") { %>
    <div class="locked-banner confidential-mode" style="margin-bottom: 60px;">
      <div class="locked-banner-overlay">
        <div class="security-badge">Access Level: CONFIDENTIAL</div>
        <h1 class="locked-title"><%- page.title %></h1>
        <p class="locked-subtitle">Electronic Cryptographic Surveillance Active</p>
      </div>
    </div>
  <% } else { %>
    <div class="post-header-box-container reveal">
      <%
        var badgeText = 'PAGE';
        var subtitleText = 'Exploring the intersection of code and aesthetics.';
        var themeColor = { accent: '#9333ea', rgb: '147, 51, 234' };
        
        if (page.type === 'about') { badgeText = 'Identity'; }
        else if (page.type === 'tags') { 
            badgeText = 'Metadata: Cloud'; 
            subtitleText = 'Neural network of categorized thoughts.';
            themeColor = { accent: '#8b5cf6', rgb: '139, 92, 246' };
        }
        else if (page.type === 'projects') { 
            badgeText = 'Portfolio: Lab'; 
            subtitleText = 'Experimental code and visual studies.';
            themeColor = { accent: '#3b82f6', rgb: '59, 130, 246' };
        }
      %>
      <div class="post-header-box" id="tilt-header" style="--theme-accent: <%= themeColor.accent %>; --theme-accent-rgb: <%= themeColor.rgb %>;">
        <div class="header-box-content">
          <div class="post-badge"><%= badgeText %></div>
          <h1 class="post-title-main"><%- page.title || 'Page' %></h1>
          <p style="margin-top: 32px; color: var(--text-secondary); font-weight: 600; font-size: 15px; opacity: 0.8; letter-spacing: 0.12em; text-transform: uppercase;"><%= subtitleText %></p>
        </div>
        <div class="header-box-decoration"></div>
      </div>
    </div>
  <% } %>

  <div class="post-content">
    <% if (page.type === "tags") { %>
      <div class="tag-cloud-container reveal" style="animation-delay: 0.4s;">
        <div class="tag-cloud-modern">
          <% site.tags.sort('name').each(function(tag) { %>
            <a href="<%- url_for(tag.path) %>" class="modern-tag-chip hover-target">
              <span class="tag-name"><%= tag.name %></span>
              <span class="tag-count"><%= tag.posts.length %></span>
            </a>
          <% }); %>
        </div>
      </div>
    <% } else if (page.type === "locked") { %>
      <div class="archive-grid" style="pointer-events: auto;">
        <% 
          var lockedList = site.locked_items || [];
          lockedList.forEach(function(post) { 
        %>
            <a href="<%- url_for(post.path) %>" class="archive-panel hover-target" style="border-color: rgba(239, 68, 68, 0.15);">
              <div style="display: flex; align-items: center; gap: 8px; color: #ef4444; margin-bottom: 12px; font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                <%- date(post.date, "YYYY-MM-DD") %>
              </div>
              <h3 class="archive-panel-title" style="margin: 0; font-size: 18px;"><%- post.title %></h3>
              <p style="margin-top: 10px; font-size: 12px; color: var(--text-secondary); opacity: 0.7;">Secure Entry - Authorized Personnel Only</p>
            </a>
        <% }); %>
      </div>
    <% } else if (page.password) { %>
      <div id="pwd-gate" style="text-align: center; padding: 100px 0;">
        <svg style="margin: 0 auto 24px; color: var(--text-secondary); width: 64px; height: 64px;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
        <h2 style="font-family: 'Bricolage Grotesque'; font-size: 32px; color: var(--text-primary); margin-bottom: 32px;">This page is encrypted.</h2>
        <div style="display: flex; gap: 8px; justify-content: center; max-width: 400px; margin: 0 auto;">
            <input type="password" id="pwd-input" placeholder="Enter security key..." style="flex: 1; padding: 12px 20px; border-radius: 12px; border: 1px solid var(--glass-border); background: var(--glass-bg); color: var(--text-primary); font-family: 'Outfit'; outline: none; font-size: 16px;">
            <button id="pwd-btn" style="padding: 12px 24px; background: #ef4444; color: #fff; border: none; border-radius: 12px; font-weight: 700; cursor: pointer; transition: all 0.3s; box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);">Decrypt</button>
        </div>
        <p id="pwd-error" style="color: #ef4444; font-size: 14px; margin-top: 16px; opacity: 0; transition: opacity 0.3s;">Access Denied. Invalid key.</p>
      </div>
      
      <div id="protected-content" style="display: none;">
        <%- page.content %>
      </div>
      <script>
        (function() {
          const btn = document.getElementById('pwd-btn');
          const input = document.getElementById('pwd-input');
          const unlock = () => {
            if(input.value === '<%= page.password %>') {
              document.getElementById('pwd-gate').style.display = 'none';
              document.getElementById('protected-content').style.display = 'block';
            } else {
              document.getElementById('pwd-error').style.opacity = '1';
            }
          };
          btn.addEventListener('click', unlock);
          input.addEventListener('keypress', (e) => { if(e.key === 'Enter') unlock(); });
        })();
      </script>
    <% } else { %>
      <%- page.content %>
    <% } %>
  </div>
</div>
</div>
</div>