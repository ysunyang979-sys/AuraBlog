<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title><%- config.title %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..800&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <% if (config.favicon) { %>
    <link rel="icon" href="<%- url_for(config.favicon) %>" type="image/png">
  <% } %>
  <script>
    // Instant dark mode initialization to prevent FOUC (Flash of Unstyled Content)
    if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.setAttribute('data-theme', 'dark');
    }
  </script>
</head>
<body>
  <!-- Ambient background elements -->
  <div class="ambient-glow"></div>
  <div class="ambient-glow"></div>

  <!-- Custom Cursor -->
  <div id="cursor"></div>
  <div id="cursor-follower"></div>
  
  <!-- Top Fade-out Blur Mask -->
  <div class="top-blur-mask"></div>

  <nav class="glass-nav">
    <a href="/" class="logo hover-target">Aura.</a>
    
    <div class="nav-middle">
      <a href="/archives" class="hover-target">Archives</a>
      <a href="/tags" class="hover-target">Tags</a>
      <a href="/projects" class="hover-target">Projects</a>
      <a href="/about" class="hover-target">About</a>
      <a href="/locked" class="hover-target" style="color: #ef4444;">Locked</a>
    </div>

    <!-- NEW: Functional & Decorative Buttons -->
    <div class="nav-actions">
      <!-- Search Mock Button -->
      <button class="action-btn hover-target" id="search-btn" aria-label="Search">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
      </button>

      <!-- Theme Toggle Switch -->
      <button class="action-btn hover-target theme-toggle-btn" id="theme-toggle" aria-label="Toggle Theme">
        <svg class="sun-icon" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
        <svg class="moon-icon" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
      </button>

      <!-- GitHub Link -->
      <a href="https://github.com" target="_blank" class="action-btn hover-target" aria-label="GitHub">
        <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path></svg>
      </a>
    </div>
  </nav>

  <main id="swup" class="transition-fade">
    <%- body %>
  </main>

  <footer class="footer">
    <p>&copy; <%- date(new Date(), 'YYYY') %> <%- config.author %>. Crafted with elegance.</p>
  </footer>
  <!-- Search Modal Overlay -->
  <div id="search-modal" class="search-modal">
    <div class="search-modal-content">
      <div class="search-header">
        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        <input type="text" id="search-input" placeholder="Type to search..." autocomplete="off">
        <button id="search-close" class="action-btn" style="width:36px;height:36px;cursor:pointer;">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      <div id="search-result" class="search-result-container"></div>
    </div>
  </div>

  <script src="/js/main.js"></script>
</body>
</html>