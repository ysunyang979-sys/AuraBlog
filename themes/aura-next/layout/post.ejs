<article class="post-detail">
<% 
    var mainTag = page.tag || (page.tags && page.tags.length ? page.tags.data[0].name : 'Thoughts'); 
    
    // Premium Design-Forward Palette
    var palette = [
      { accent: '#9333ea', rgb: '147, 51, 234' }, // Royal Purple
      { accent: '#3b82f6', rgb: '59, 130, 246' }, // Oceanic Blue
      { accent: '#06b6d4', rgb: '6, 182, 212' },   // Cyber Cyan
      { accent: '#f97316', rgb: '249, 115, 22' },  // Neon Orange
      { accent: '#f43f5e', rgb: '244, 63, 94' },   // Rose Pink
      { accent: '#10b981', rgb: '16, 185, 129' },  // Emerald Sea
      { accent: '#6366f1', rgb: '99, 102, 241' },  // Indigo Mist
      { accent: '#8b5cf6', rgb: '139, 92, 246' }   // Violet Glow
    ];

    // Simple deterministic hash to pick a color
    var hash = 0;
    var tagStr = String(mainTag).toLowerCase();
    for (var i = 0; i < tagStr.length; i++) {
      hash = tagStr.charCodeAt(i) + ((hash << 5) - hash);
    }
    var colorIndex = Math.abs(hash) % palette.length;
    var theme = palette[colorIndex];

    // Manual overrides for specific core tags (optional, for even better curation)
    if (tagStr === 'ai') theme = { accent: '#06b6d4', rgb: '6, 182, 212' };
    if (tagStr === '科学上网') theme = { accent: '#9333ea', rgb: '147, 51, 234' };
    if (tagStr === '软件') theme = { accent: '#f97316', rgb: '249, 115, 22' };
  %>
  <div class="post-header-box-container reveal">
    <div class="post-header-box" id="tilt-header" style="--theme-accent: <%= theme.accent %>; --theme-accent-rgb: <%= theme.rgb %>;">
      <div class="header-box-content">
        <div class="post-badge"><%= mainTag %></div>
        <h1 class="post-title-main"><%- page.title %></h1>
      </div>
      <div class="header-box-decoration"></div>
    </div>
  </div>

  <!-- Tilt effect removed for minimalist consistency -->


  <% if (toc(page.content) !== '') { %>
    <aside class="post-toc" id="post-toc" <% if (page.password) { %>style="display: none;"<% } %>>
      <div class="toc-header">
        <span class="toc-title">Contents</span>
        <button class="action-btn hover-target toc-toggle" id="toc-toggle" aria-label="Toggle TOC">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path></svg>
        </button>
      </div>
      <div class="toc-content">
        <%- toc(page.content, {list_number: false}) %>
      </div>
    </aside>
  <% } %>

  <% if (page.password) { %>
    <div id="pwd-gate" style="text-align: center; padding: 100px 0;">
      <svg style="margin: 0 auto 24px; color: var(--text-secondary); width: 64px; height: 64px;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
      <h2 style="font-family: 'Bricolage Grotesque'; font-size: 32px; color: var(--text-primary); margin-bottom: 32px;">This article is encrypted.</h2>
      <div style="display: flex; gap: 8px; justify-content: center; max-width: 400px; margin: 0 auto;">
          <input type="password" id="pwd-input" placeholder="Enter security key..." style="flex: 1; padding: 12px 20px; border-radius: 12px; border: 1px solid var(--glass-border); background: var(--glass-bg); color: var(--text-primary); font-family: 'Outfit'; outline: none; font-size: 16px;">
          <button id="pwd-btn" style="padding: 12px 24px; background: #ef4444; color: #fff; border: none; border-radius: 12px; font-weight: 700; cursor: pointer; transition: all 0.3s; box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);">Decrypt</button>
      </div>
      <p id="pwd-error" style="color: #ef4444; font-size: 14px; margin-top: 16px; opacity: 0; transition: opacity 0.3s;">Access Denied. Invalid key.</p>
    </div>
    
    <div id="protected-content" class="post-content" style="display: none;">
      <%- page.content %>
    </div>
    <script>
      (function() {
        const btn = document.getElementById('pwd-btn');
        const input = document.getElementById('pwd-input');
        const unlock = () => {
          if(input.value === '<%= page.password %>') {
            document.getElementById('pwd-gate').style.display = 'none';
            document.getElementById('protected-content').style.display = 'block';
            // Show TOC if it exists (re-rendered or unhidden)
            const toc = document.getElementById('post-toc');
            if(toc) toc.style.display = 'block';
          } else {
            document.getElementById('pwd-error').style.opacity = '1';
          }
        };
        btn.addEventListener('click', unlock);
        input.addEventListener('keypress', (e) => { if(e.key === 'Enter') unlock(); });
      })();
    </script>
  <% } else { %>
    <div class="post-content">
      <%- page.content %>
    </div>
  <% } %>

  <% if (page.tags && page.tags.length) { %>
    <div class="post-tags-container">
      <% page.tags.forEach(function(tag) { %>
        <a href="<%- url_for(tag.path) %>" class="tag-btn hover-target">
          <%= tag.name %>
        </a>
      <% }) %>
    </div>
  <% } %>

  <!-- Floating Pagination (Prev/Next) -->
  <%
    var isLocked = !!page.password;
    var validPrev = page.prev;
    while(validPrev && !!validPrev.password !== isLocked) { validPrev = validPrev.prev; }
    
    var validNext = page.next;
    while(validNext && !!validNext.password !== isLocked) { validNext = validNext.next; }
  %>
  <div class="floating-pagination">
    <% if (validPrev) { %>
      <a href="<%- url_for(validPrev.path) %>" class="float-btn float-prev hover-target" title="上一篇文章 / Previous">
        <span class="float-btn-label">上一篇</span>
        <span class="float-btn-title"><%- validPrev.title %></span>
      </a>
    <% } %>
    <% if (validNext) { %>
      <a href="<%- url_for(validNext.path) %>" class="float-btn float-next hover-target" title="下一篇文章 / Next">
        <span class="float-btn-label">下一篇</span>
        <span class="float-btn-title"><%- validNext.title %></span>
      </a>
    <% } %>
  </div>
</article>