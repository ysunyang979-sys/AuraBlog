<div class="archive-page" id="swup-archive">
  <div class="post-header-box-container reveal">
    <div class="post-header-box" id="tilt-header" style="--theme-accent: #9333ea; --theme-accent-rgb: 147, 51, 234;">
      <div class="header-box-content">
        <div class="post-badge">Database: Chronicles</div>
        <h1 class="post-title-main">Archives.</h1>
        <p style="margin-top: 32px; color: var(--text-secondary); font-weight: 600; font-size: 16px; opacity: 0.8; letter-spacing: 0.1em; text-transform: uppercase;">A collection of creative explorations and notes.</p>
      </div>
      <div class="header-box-decoration"></div>
    </div>
  </div>
  
  <div class="archive-grid">
    <% page.posts.forEach(function(post){ %>
      <a href="<%- url_for(post.path) %>" class="archive-panel hover-target">
        <span class="archive-panel-date"><%- date(post.date, "MMM D, YYYY") %></span>
        <h3 class="archive-panel-title"><%- post.title || 'Untitled Thought' %></h3>
      </a>
    <% }) %>
  </div>

  <div class="pagination">
    <%- paginator({
      prev_text: 'Prev',
      next_text: 'Next'
    }) %>
  </div>
</div>
