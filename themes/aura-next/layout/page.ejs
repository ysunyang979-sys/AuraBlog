<div class="page-detail">
  <header class="page-header">
    <h1><%- page.title || 'Page' %></h1>
  </header>

  <% if (page.cover) { %>
    <div class="post-hero-image" style="margin-top: 20px; margin-bottom: 60px;">
      <img src="<%- url_for(page.cover) %>" alt="<%- page.title %>">
    </div>
  <% } %>

  <div class="post-content">
    <% if (page.type === "tags") { %>
      <div class="tag-cloud">
        <%- tagcloud(site.tags, {
          min_font: 14,
          max_font: 32,
          amount: 200,
          color: true,
          start_color: '#a1a1aa',
          end_color: '#9333ea'
        }) %>
      </div>
    <% } else if (page.type === "locked") { %>
      <div class="archive-grid" style="pointer-events: auto;">
        <% 
          var lockedPosts = site.posts.filter(p => !!p.password).sort('date', -1).limit(9);
          lockedPosts.each(function(post) { 
        %>
            <a href="<%- url_for(post.path) %>" class="archive-panel hover-target" style="border-color: rgba(239, 68, 68, 0.1);">
              <div style="display: flex; align-items: center; gap: 8px; color: #ef4444; margin-bottom: 8px; font-size: 13px; font-weight: 600; text-transform: uppercase;">
                <svg width="12" height="12" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C9.243 2 7 4.243 7 7v3H6c-1.103 0-2 .897-2 2v8c0 1.103.897 2 2 2h12c1.103 0 2-.897 2-2v-8c0-1.103-.897-2-2-2h-1V7c0-2.757-2.243-5-5-5zm0 2c1.654 0 3 1.346 3 3v3H9V7c0-1.654 1.346-3 3-3zm-5 7h10v8H7v-8z"></path></svg>
                <%- date(post.date, "MMM D, YYYY") %>
              </div>
              <h3 class="archive-panel-title"><%- post.title %></h3>
            </a>
        <% }); %>
      </div>
    <% } else { %>
      <%- page.content %>
    <% } %>
  </div>
</div>
