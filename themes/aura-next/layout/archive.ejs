<div class="archive-page" id="swup-archive">
  <div class="archive-header">
    <h1>All Thoughts.</h1>
    <p class="archive-desc" style="color: var(--text-secondary); font-size: 16px;">A collection of creative explorations and notes.</p>
  </div>
  
  <div class="archive-grid">
    <% page.posts.forEach(function(post){ %>
      <% if (!post.password) { %>
        <a href="<%- url_for(post.path) %>" class="archive-panel hover-target">
          <span class="archive-panel-date"><%- date(post.date, "MMM D, YYYY") %></span>
          <h3 class="archive-panel-title"><%- post.title %></h3>
        </a>
      <% } %>
    <% }) %>
  </div>

  <div class="pagination">
    <%- paginator({
      prev_text: 'Prev',
      next_text: 'Next'
    }) %>
  </div>
</div>
